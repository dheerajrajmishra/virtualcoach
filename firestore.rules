rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all access for testing.
    // WARNING: This is insecure and should not be used in production.
    match /{document=**} {
      allow read, write: if true;
    }

    /* --- Previous Secure Rules ---
